<div style="max-width:900px;margin:0 auto;padding:8rem 2rem 4rem;">
  <h1 style="font-family:'Cinzel',serif;font-size:clamp(1.5rem,3vw,2.5rem);font-weight:700;letter-spacing:0.08em;margin-bottom:2rem;background:linear-gradient(135deg,#E8E0F0,#c9a84c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">{{ page.title }}</h1>
  <div style="color:#a09ab8;font-family:'Inter',sans-serif;font-size:0.92rem;line-height:1.8;">
    {{ page.content }}
  </div>
</div>

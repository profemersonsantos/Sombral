<!-- ============================================================
REVIEWS SECTION — Integração Supabase
Substitua SUPABASE_URL e SUPABASE_ANON_KEY pelos seus valores
============================================================ -->
{% assign supabase_url = "https://rejbreflfppxjmvpbjtw.supabase.co" %}
{% assign supabase_anon = "sb_publishable_hy2klYha_dRnijT6l3SJ4A_Gi3WrKRC" %}
<section class="sombral-reviews" id="reviews-section">
<div class="rv-container">
<!-- CABEÇALHO -->
<div class="rv-header">
<h2 class="rv-title">Avaliações dos clientes</h2>
<div class="rv-summary" id="rv-summary">
<span class="rv-avg" id="rv-avg">—</span>
<div class="rv-stars-display" id="rv-stars-display"></div>
<span class="rv-count" id="rv-count">carregando...</span>
</div>
</div>
<!-- LISTA DE REVIEWS -->
<div class="rv-list" id="rv-list">
<div class="rv-loading">Carregando avaliações…</div>
</div>
<!-- FORMULÁRIO DE ENVIO -->
<div class="rv-form-wrap">
<h3 class="rv-form-title">Deixe sua avaliação</h3>
<div class="rv-form" id="rv-form">
<div class="rv-field">
<label>Sua nota</label>
<div class="rv-star-picker" id="rv-star-picker">
<span data-v="1">★</span>
<span data-v="2">★</span>
<span data-v="3">★</span>
<span data-v="4">★</span>
<span data-v="5">★</span>
</div>
<input type="hidden" id="rv-stars-input" value="0">
</div>
<div class="rv-row">
<div class="rv-field">
<label for="rv-name">Nome</label>
<input type="text" id="rv-name" placeholder="Seu nome" maxlength="60">
</div>
<div class="rv-field">
<label for="rv-city">Cidade (opcional)</label>
<input type="text" id="rv-city" placeholder="Ex: São Paulo" maxlength="60">
</div>
</div>
<div class="rv-field">
<label for="rv-text">Comentário</label>
<textarea id="rv-text" rows="4" placeholder="Conte sua experiência com o produto…" maxlength="800"></textarea>
</div>
<button class="rv-submit" id="rv-submit" type="button">Enviar avaliação</button>
<p class="rv-notice">Sua avaliação será publicada após aprovação.</p>
<p class="rv-msg" id="rv-msg"></p>
</div>
</div>
</div>
</section>
<style>
.sombral-reviews {
--rv-bg: #fff;
--rv-border: #e8e8e8;
--rv-gold: #f5a623;
--rv-text: #1a1a1a;
--rv-muted: #666;
--rv-accent: #1a1a1a;
--rv-radius: 10px;
font-family: 'Helvetica Neue', Arial, sans-serif;
background: var(--rv-bg);
padding: 48px 0;
}
.rv-container {
max-width: 860px;
margin: 0 auto;
padding: 0 20px;
}
.rv-header { margin-bottom: 32px; }
.rv-title {
font-size: 1.6rem;
font-weight: 700;
margin: 0 0 12px;
color: var(--rv-text);
}
.rv-summary {
display: flex;
align-items: center;
gap: 10px;
flex-wrap: wrap;
}
.rv-avg {
font-size: 2rem;
font-weight: 800;
color: var(--rv-text);
}
.rv-stars-display span { color: var(--rv-gold); font-size: 1.2rem; }
.rv-count { color: var(--rv-muted); font-size: 0.9rem; }
/* LISTA */
.rv-list { display: flex; flex-direction: column; gap: 16px; margin-bottom: 40px; }
.rv-loading { color: var(--rv-muted); padding: 20px 0; }
.rv-empty { color: var(--rv-muted); padding: 20px 0; font-style: italic; }
.rv-card {
border: 1px solid var(--rv-border);
border-radius: var(--rv-radius);
padding: 20px 24px;
background: #fafafa;
}
.rv-card-header {
display: flex;
justify-content: space-between;
align-items: flex-start;
margin-bottom: 8px;
flex-wrap: wrap;
gap: 6px;
}
.rv-card-name { font-weight: 700; color: var(--rv-text); }
.rv-card-city { color: var(--rv-muted); font-size: 0.85rem; }
.rv-card-stars span { color: var(--rv-gold); }
.rv-card-date { color: var(--rv-muted); font-size: 0.8rem; }
.rv-card-text { color: var(--rv-text); line-height: 1.6; margin: 0; }
/* FORMULÁRIO */
.rv-form-wrap {
border-top: 2px solid var(--rv-border);
padding-top: 36px;
}
.rv-form-title {
font-size: 1.2rem;
font-weight: 700;
margin: 0 0 24px;
color: var(--rv-text);
}
.rv-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.rv-field label { font-size: 0.85rem; font-weight: 600; color: var(--rv-text); }
.rv-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media(max-width:560px){ .rv-row { grid-template-columns: 1fr; } }
.rv-field input,
.rv-field textarea {
border: 1px solid var(--rv-border);
border-radius: 6px;
padding: 10px 14px;
font-size: 0.95rem;
color: var(--rv-text);
background: #fff;
transition: border-color .2s;
outline: none;
width: 100%;
box-sizing: border-box;
}
.rv-field input:focus,
.rv-field textarea:focus { border-color: var(--rv-accent); }
.rv-field textarea { resize: vertical; min-height: 90px; }
/* STAR PICKER */
.rv-star-picker { display: flex; gap: 4px; cursor: pointer; }
.rv-star-picker span {
font-size: 1.8rem;
color: #ddd;
transition: color .15s, transform .1s;
user-select: none;
}
.rv-star-picker span.active { color: var(--rv-gold); }
.rv-star-picker span:hover { transform: scale(1.15); }
/* BOTÃO */
.rv-submit {
background: var(--rv-accent);
color: #fff;
border: none;
border-radius: 6px;
padding: 12px 28px;
font-size: 1rem;
font-weight: 600;
cursor: pointer;
transition: opacity .2s;
margin-top: 4px;
}
.rv-submit:hover { opacity: .82; }
.rv-submit:disabled { opacity: .5; cursor: not-allowed; }
.rv-notice { color: var(--rv-muted); font-size: 0.8rem; margin: 8px 0 0; }
.rv-msg { font-size: 0.9rem; margin: 10px 0 0; min-height: 20px; font-weight: 600; }
.rv-msg.ok { color: #2e7d32; }
.rv-msg.err { color: #c62828; }
</style>
<script>
(function(){
const SUPABASE_URL = {{ supabase_url | json }};
const SUPABASE_ANON = {{ supabase_anon | json }};
const PRODUCT_HANDLE = {{ product.handle | json }};
/* ---- HEADERS ---- */
const headers = {
'apikey': SUPABASE_ANON,
'Authorization': 'Bearer ' + SUPABASE_ANON,
'Content-Type': 'application/json'
};
/* ---- ESTRELAS HELPER ---- */
function starsHTML(n){
return Array.from({length:5}, (_,i)=>
`<span style="color:${i<n?'#f5a623':'#ddd'}">${i<n?'★':'☆'}</span>`
).join('');
}
/* ---- CARREGAR REVIEWS ---- */
async function loadReviews(){
const list = document.getElementById('rv-list');
const avg = document.getElementById('rv-avg');
const stars = document.getElementById('rv-stars-display');
const count = document.getElementById('rv-count');
try {
const res = await fetch(
`${SUPABASE_URL}/rest/v1/reviews?product_handle=eq.${encodeURIComponent(PRODUCT_HANDLE)}&status=eq.approved&order=created_at.desc`,
{ headers }
);
const data = await res.json();
if (!data.length) {
list.innerHTML = '<p class="rv-empty">Nenhuma avaliação ainda. Seja o primeiro!</p>';
avg.textContent = '—';
count.textContent = '0 avaliações';
return;
}
const media = (data.reduce((s,r)=>s+r.stars,0)/data.length).toFixed(1);
avg.textContent = media;
stars.innerHTML = starsHTML(Math.round(media));
count.textContent = `${data.length} avaliação${data.length!==1?'s':''}`;
list.innerHTML = data.map(r => {
const dt = new Date(r.created_at).toLocaleDateString('pt-BR',{day:'2-digit',month:'short',year:'numeric'});
return `
<div class="rv-card">
<div class="rv-card-header">
<div>
<span class="rv-card-name">${escHTML(r.name)}</span>
${r.city ? `<span class="rv-card-city"> · ${escHTML(r.city)}</span>` : ''}
</div>
<div style="display:flex;gap:10px;align-items:center">
<span class="rv-card-stars">${starsHTML(r.stars)}</span>
<span class="rv-card-date">${dt}</span>
</div>
</div>
<p class="rv-card-text">${escHTML(r.text)}</p>
</div>`;
}).join('');
} catch(e){
list.innerHTML = '<p class="rv-empty">Erro ao carregar avaliações.</p>';
console.error('[Reviews]', e);
}
}
/* ---- STAR PICKER ---- */
const picker = document.getElementById('rv-star-picker');
const starsInput = document.getElementById('rv-stars-input');
picker.querySelectorAll('span').forEach(s => {
s.addEventListener('click', ()=>{
const v = +s.dataset.v;
starsInput.value = v;
picker.querySelectorAll('span').forEach(x => x.classList.toggle('active', +x.dataset.v <= v));
});
s.addEventListener('mouseover', ()=>{
const v = +s.dataset.v;
picker.querySelectorAll('span').forEach(x => x.classList.toggle('active', +x.dataset.v <= v));
});
s.addEventListener('mouseout', ()=>{
const sel = +starsInput.value;
picker.querySelectorAll('span').forEach(x => x.classList.toggle('active', +x.dataset.v <= sel));
});
});
/* ---- ENVIO ---- */
document.getElementById('rv-submit').addEventListener('click', async ()=>{
const msg = document.getElementById('rv-msg');
const btn = document.getElementById('rv-submit');
const stars = +document.getElementById('rv-stars-input').value;
const name = document.getElementById('rv-name').value.trim();
const city = document.getElementById('rv-city').value.trim();
const text = document.getElementById('rv-text').value.trim();
msg.className = 'rv-msg';
if(!stars){ msg.textContent='Selecione uma nota.'; msg.className='rv-msg err'; return; }
if(!name) { msg.textContent='Informe seu nome.'; msg.className='rv-msg err'; return; }
if(!text) { msg.textContent='Escreva um comentário.'; msg.className='rv-msg err'; return; }
btn.disabled = true;
btn.textContent = 'Enviando…';
try {
const res = await fetch(`${SUPABASE_URL}/rest/v1/reviews`, {
method: 'POST',
headers: { ...headers, 'Prefer': 'return=minimal' },
body: JSON.stringify({ product_handle: PRODUCT_HANDLE, stars, name, city, text })
});
if(!res.ok) throw new Error(await res.text());
msg.textContent = '✓ Avaliação enviada! Será publicada após aprovação.';
msg.className = 'rv-msg ok';
document.getElementById('rv-name').value = '';
document.getElementById('rv-city').value = '';
document.getElementById('rv-text').value = '';
starsInput.value = 0;
picker.querySelectorAll('span').forEach(x=>x.classList.remove('active'));
} catch(e){
msg.textContent = 'Erro ao enviar. Tente novamente.';
msg.className = 'rv-msg err';
console.error('[Reviews]', e);
}
btn.disabled = false;
btn.textContent = 'Enviar avaliação';
});
/* ---- ESCAPE HTML ---- */
function escHTML(s){ const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }
/* ---- INIT ---- */
loadReviews();
})();
</script>

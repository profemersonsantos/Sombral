var data=allData[handle];
function makeCard(r){
var sc=r.stars<=3?'s3'🙁r.stars===4?'s4':'');
var stars='★'.repeat(r.stars)+'☆'.repeat(5-r.stars);
return '<div class="review-card">'+
'<span class="review-stars '+sc+'">'+stars+'</span>'+
'<p class="review-text">"'+r.text+'"</p>'+
'<div class="review-footer">'+
'<div><p class="review-name">'+r.name+(r.ctx?' · <span style="font-weight:400;color:var(--text-muted)">'+r.ctx+'</span>':'')+' </p>'+
'<p class="review-city">'+r.city+'</p></div>'+
'<span class="review-verified">✓ Verificado</span>'+
'</div></div>';
}
function renderNav(){
var navEl=document.getElementById('reviews-nav');
if(!navEl)return;
var list=window._revList;
var total=Math.ceil(list.length/PER_PAGE);
navEl.innerHTML=
'<button class="rev-btn" onclick="window.revNav(-1)" '+(currentPage===0?'disabled':'')+'>&#8249;</button>'+
'<span class="rev-info">Mostrando '+(currentPage*PER_PAGE+1)+'-'+Math.min((currentPage+1)*PER_PAGE,list.length)+' de '+list.length+' avaliações</span>'+
'<button class="rev-btn" onclick="window.revNav(1)" '+(currentPage>=total-1?'disabled':'')+'>&#8250;</button>'+
(total>1?'<button class="rev-ver-todas" onclick="window.verTodas()">VER TODAS ('+list.length+')</button>':'');
}
function renderGrid(){
var gridEl=document.getElementById('reviews-grid');
if(!gridEl)return;
var list=window._revList;
var items=list.slice(currentPage*PER_PAGE,(currentPage+1)*PER_PAGE);
gridEl.innerHTML=items.map(makeCard).join('');
renderNav();
}
window.revNav=function(dir){
var total=Math.ceil(window._revList.length/PER_PAGE);
currentPage=Math.max(0,Math.min(currentPage+dir,total-1));
renderGrid();
document.getElementById('reviews-grid').scrollIntoView({behavior:'smooth',block:'nearest'});
};
window.verTodas=function(){
var gridEl=document.getElementById('reviews-grid');
var navEl=document.getElementById('reviews-nav');
gridEl.innerHTML=window._revList.map(makeCard).join('');
navEl.innerHTML='<button class="rev-ver-todas" onclick="window.recolher()">RECOLHER</button>';
};
window.recolher=function(){
currentPage=0;
renderGrid();
};
window._renderReviews=renderGrid;
window._setCurrentPage=function(p){currentPage=p;};
if(data){
window._revList=data.reviews.slice();
// Rating inline
var rEl=document.getElementById('product-rating-inline');
if(rEl)rEl.innerHTML='<span class="stars-inline">'+'★'.repeat(Math.round(data.avg))+'☆'.repeat(5-Math.round(data.avg))+'</span><span class="rating-text">'+data.avg.toFixed(1)+' · '+data.total+' avaliações</span>';
// Summary
var topEl=document.getElementById('reviews-top');
if(topEl){
var bars=[[5,'5 ★'],[4,'4 ★'],[3,'3 ★']].map(function(b){
return '<div class="bar-row"><span class="bar-label">'+b[1]+'</span><div class="bar-track"><div class="bar-fill" style="width:'+(data.dist[b[0]]||0)+'%"></div></div><span class="bar-pct">'+(data.dist[b[0]]||0)+'%</span></div>';
}).join('');
topEl.innerHTML='<div class="reviews-summary-box"><div class="reviews-avg-num">'+data.avg.toFixed(1)+'</div><div class="reviews-avg-stars">★★★★★</div><div class="reviews-total">'+data.total+' avaliações</div></div><div class="reviews-bars">'+bars+'</div>';
}
var tEl=document.getElementById('reviews-title-line');
if(tEl)tEl.textContent='✦ O que dizem as Sombras ('+data.reviews.length+' avaliações recentes)';
renderGrid();
}
// ---- FORM SUBMIT ----
window.submitReview=function(){
var stars=document.querySelector('input[name="stars"]:checked');
var name=document.getElementById('review-name').value.trim();
var city=document.getElementById('review-city').value.trim();
var text=document.getElementById('review-text').value.trim();
if(!stars){alert('Selecione uma nota em estrelas.');return;}
if(!name){alert('Digite seu nome.');return;}
if(text.length<20){alert('Escreva ao menos 20 caracteres.');return;}
var nr={stars:parseInt(stars.value),name:name.replace(/</g,'&lt;'),city:city||'Brasil',ctx:'',text:text.replace(/</g,'&lt;')};
if(window._revList){window._revList.unshift(nr);window._setCurrentPage(0);window._renderReviews();}
document.querySelectorAll('input[name="stars"]').forEach(function(i){i.checked=false;});
document.getElementById('review-name').value='';
document.getElementById('review-city').value='';
document.getElementById('review-text').value='';
var msg=document.getElementById('review-success');
msg.style.display='block';
setTimeout(function(){msg.style.display='none';},4000);
};
})();
</script>

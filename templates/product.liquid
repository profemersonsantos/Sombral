{% assign current_variant = product.selected_or_first_available_variant %}
<style>
.product-page{display:grid;grid-template-columns:1fr 1fr;gap:3rem;max-width:1100px;margin:0 auto;padding:8rem 2rem 4rem;align-items:start;}
.product-gallery{position:sticky;top:7rem;}
.product-main-image{width:100%;aspect-ratio:1/1;max-height:500px;overflow:visible;border:none;background:transparent;display:flex;align-items:center;justify-content:center;position:relative;}
.product-main-image img{width:100%;height:100%;object-fit:contain;transition:opacity 0.3s ease;background:transparent;mix-blend-mode:multiply;}
.gallery-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);border:1px solid var(--accent);color:var(--gold);width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.2rem;z-index:10;transition:all 0.2s;}
.gallery-nav:hover{background:rgba(123,47,190,0.4);border-color:var(--gold);}
.gallery-nav.prev{left:8px;}.gallery-nav.next{right:8px;}
.gallery-counter{position:absolute;bottom:8px;right:10px;font-family:'Cinzel',serif;font-size:0.65rem;color:var(--text-muted);background:rgba(0,0,0,0.5);padding:2px 6px;}
.product-thumbs{display:flex;gap:0.5rem;margin-top:0.6rem;flex-wrap:wrap;}
.product-thumb{width:60px;height:60px;overflow:visible;border:1px solid var(--border);background:transparent;cursor:pointer;transition:all 0.2s;}
.product-thumb img{width:100%;height:100%;object-fit:contain;background:transparent;mix-blend-mode:multiply;}
.product-thumb.active{border-color:var(--accent);box-shadow:0 0 8px rgba(123,47,190,0.4);}
.product-thumb:hover{border-color:var(--gold);}
.breadcrumb{max-width:1100px;margin:0 auto;padding:7rem 2rem 0;font-size:0.8rem;color:var(--text-muted);font-family:'Cinzel',serif;letter-spacing:0.06em;}
.breadcrumb a{color:var(--text-muted);transition:color 0.2s;}.breadcrumb a:hover{color:var(--text);}
.breadcrumb-sep{margin:0 0.5rem;color:var(--accent);}
.product-info{display:flex;flex-direction:column;gap:1.2rem;}
.product-info-title{font-family:'Cinzel',serif;font-size:clamp(1.2rem,2.5vw,1.8rem);font-weight:700;line-height:1.3;}
.product-info-price{font-family:'Cinzel',serif;font-size:1.6rem;font-weight:900;color:var(--gold);}
.product-rating-inline{display:flex;align-items:center;gap:0.6rem;}
.stars-inline{color:var(--gold);font-size:0.9rem;letter-spacing:1px;}
.rating-text{font-family:'Cinzel',serif;font-size:0.72rem;color:var(--text-muted);letter-spacing:0.06em;}
.variant-label{display:block;font-family:'Cinzel',serif;font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.5rem;}
.variant-options{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;}
.variant-option{padding:0.5rem 1rem;background:var(--bg-card);border:1px solid var(--border);color:var(--text-muted);font-family:'Cinzel',serif;font-size:0.75rem;letter-spacing:0.06em;cursor:pointer;transition:all 0.2s;user-select:none;}
.variant-option:hover{border-color:var(--accent);color:var(--text);}
.variant-option.active{background:rgba(123,47,190,0.15);border-color:var(--accent);color:var(--text);}
.frete-bar{display:flex;align-items:center;justify-content:center;gap:0.5rem;background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.25);padding:0.55rem 1rem;margin-bottom:0.5rem;}
.frete-bar span{font-family:'Cinzel',serif;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;color:#c9a84c;}
.delivery-estimate{display:flex;align-items:center;gap:0.7rem;background:rgba(37,211,102,0.06);border:1px solid rgba(37,211,102,0.2);padding:0.6rem 1rem;margin-bottom:0.5rem;}
.delivery-icon{font-size:1.2rem;line-height:1;}
.delivery-info{display:flex;flex-direction:column;gap:0.1rem;}
.delivery-label{font-family:'Cinzel',serif;font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(37,211,102,0.7);}
.delivery-date{font-family:'Cinzel',serif;font-size:0.78rem;font-weight:600;color:#25d366;letter-spacing:0.06em;}
.product-add-btn{width:100%;background:linear-gradient(135deg,#8b0050,var(--cta));color:#fff;font-family:'Cinzel',serif;font-size:0.85rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:1rem;border:none;cursor:pointer;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:all 0.3s;box-shadow:0 0 20px rgba(196,30,138,0.3);}
.product-add-btn:hover{transform:translateY(-2px);box-shadow:0 0 30px rgba(196,30,138,0.5);}
.btn-wp{display:flex;align-items:center;justify-content:center;gap:0.5rem;background:transparent;border:1px solid #25d366;color:#25d366;font-family:'Cinzel',serif;font-size:0.78rem;letter-spacing:0.1em;padding:0.8rem;text-decoration:none;transition:all 0.2s;}
.btn-wp:hover{background:rgba(37,211,102,0.1);}
.product-guarantees{display:flex;gap:1rem;flex-wrap:wrap;padding-top:1rem;border-top:1px solid var(--border);font-size:0.72rem;color:var(--text-muted);font-family:'Cinzel',serif;letter-spacing:0.05em;}
.product-desc{color:var(--text-muted);font-size:0.88rem;line-height:1.7;padding-top:1rem;border-top:1px solid var(--border);}
/* RELACIONADOS */
.related-section{max-width:1100px;margin:0 auto;padding:2rem 2rem 0;}
.related-title{font-family:'Cinzel',serif;font-size:1rem;font-weight:700;letter-spacing:0.1em;color:var(--text);margin-bottom:1.5rem;padding-bottom:0.8rem;border-bottom:1px solid var(--border);}
.related-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;}
.related-card{background:var(--bg-card);border:1px solid var(--border);overflow:hidden;transition:all 0.3s;text-decoration:none;display:flex;flex-direction:column;}
.related-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 6px 20px rgba(123,47,190,0.2);}
.related-card-img{aspect-ratio:1/1;overflow:hidden;background:rgba(255,255,255,0.03);position:relative;}
.related-card-img img{width:100%;height:100%;object-fit:contain;filter:brightness(1.15);transition:all 0.3s;background:transparent;}
.related-card:hover .related-card-img img{transform:scale(1.05);filter:brightness(1.25);}
.related-card-info{padding:0.9rem;}
.related-card-title{font-family:'Cinzel',serif;font-size:0.75rem;font-weight:600;letter-spacing:0.04em;line-height:1.4;color:var(--text);margin-bottom:0.4rem;}
.related-card-price{font-family:'Cinzel',serif;font-size:0.9rem;font-weight:700;color:var(--gold);}
.related-card-btn{margin:0 0.9rem 0.9rem;display:block;background:linear-gradient(135deg,#8b0050,var(--cta));color:#fff;font-family:'Cinzel',serif;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:0.6rem;text-align:center;border:none;cursor:pointer;transition:all 0.2s;text-decoration:none;}
.related-card-btn:hover{opacity:0.85;}
/* REVIEWS */
.reviews-section{max-width:1100px;margin:0 auto;padding:3rem 2rem 4rem;}
.reviews-top{display:flex;align-items:flex-start;gap:3rem;margin-bottom:2.5rem;flex-wrap:wrap;}
.reviews-summary-box{background:var(--bg-card);border:1px solid var(--border);padding:1.5rem 2rem;text-align:center;min-width:160px;}
.reviews-avg-num{font-family:'Cinzel',serif;font-size:3rem;font-weight:900;color:var(--gold);line-height:1;}
.reviews-avg-stars{color:var(--gold);font-size:1.1rem;letter-spacing:2px;margin:0.4rem 0;}
.reviews-total{font-size:0.72rem;color:var(--text-muted);font-family:'Cinzel',serif;}
.reviews-bars{flex:1;min-width:200px;display:flex;flex-direction:column;gap:0.5rem;justify-content:center;}
.bar-row{display:flex;align-items:center;gap:0.7rem;}
.bar-label{font-family:'Cinzel',serif;font-size:0.72rem;color:var(--text-muted);min-width:48px;text-align:right;}
.bar-track{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden;}
.bar-fill{height:100%;background:var(--gold);border-radius:3px;}
.bar-pct{font-size:0.68rem;color:var(--text-muted);min-width:30px;}
.reviews-title-line{font-family:'Cinzel',serif;font-size:1rem;font-weight:700;letter-spacing:0.1em;color:var(--text);margin-bottom:1.5rem;padding-bottom:0.8rem;border-bottom:1px solid var(--border);}
.reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.2rem;margin-bottom:1.5rem;}
.review-card{background:var(--bg-card);border:1px solid var(--border);border-left:3px solid var(--accent);padding:1.4rem;display:flex;flex-direction:column;gap:0.7rem;transition:border-color 0.2s;}
.review-card:hover{border-left-color:var(--cta);}
.review-stars{color:var(--gold);font-size:0.82rem;letter-spacing:2px;}
.review-stars.s3{color:#b8860b;}.review-stars.s4{color:#c9a030;}
.review-text{font-family:'Crimson Text',serif;font-style:italic;font-size:0.93rem;color:var(--text-muted);line-height:1.65;flex:1;}
.review-footer{display:flex;justify-content:space-between;align-items:center;padding-top:0.7rem;border-top:1px solid var(--border);}
.review-name{font-family:'Cinzel',serif;font-size:0.72rem;font-weight:700;letter-spacing:0.08em;}
.review-city{font-size:0.68rem;color:var(--text-muted);margin-top:0.1rem;}
.review-verified{font-size:0.62rem;color:#25d366;font-family:'Cinzel',serif;}
.reviews-nav{display:flex;align-items:center;justify-content:center;gap:0.8rem;margin-bottom:2rem;flex-wrap:wrap;}
.rev-btn{background:var(--bg-card);border:1px solid var(--accent);color:var(--gold);width:42px;height:42px;font-size:1.3rem;cursor:pointer;transition:all 0.2s;font-family:serif;display:flex;align-items:center;justify-content:center;}
.rev-btn:hover:not(:disabled){background:rgba(123,47,190,0.2);}
.rev-btn:disabled{opacity:0.3;cursor:default;}
.rev-info{font-family:'Cinzel',serif;font-size:0.72rem;color:var(--text-muted);letter-spacing:0.08em;text-align:center;min-width:160px;}
.rev-ver-todas{background:transparent;border:1px solid var(--border);color:var(--text-muted);font-family:'Cinzel',serif;font-size:0.68rem;letter-spacing:0.08em;padding:0.5rem 1rem;cursor:pointer;transition:all 0.2s;}
.rev-ver-todas:hover{border-color:var(--accent);color:var(--text);}
.review-form-section{background:var(--bg-card);border:1px solid var(--border);padding:2rem;margin-top:0.5rem;}
.review-form-title{font-family:'Cinzel',serif;font-size:0.95rem;font-weight:700;letter-spacing:0.08em;margin-bottom:1.5rem;}
.star-picker{display:flex;gap:0.4rem;margin-bottom:1.2rem;flex-direction:row-reverse;justify-content:flex-end;}
.star-picker input{display:none;}
.star-picker label{font-size:1.8rem;color:var(--border);cursor:pointer;transition:color 0.15s;line-height:1;}
.star-picker label:hover,.star-picker label:hover ~ label,.star-picker input:checked ~ label{color:var(--gold);}
.review-form-group{margin-bottom:1rem;}
.review-form-group label{display:block;font-family:'Cinzel',serif;font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.4rem;}
.review-form-group input,.review-form-group textarea{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:'Inter',sans-serif;font-size:0.88rem;padding:0.7rem 1rem;outline:none;transition:border-color 0.2s;resize:vertical;}
.review-form-group input:focus,.review-form-group textarea:focus{border-color:var(--accent);}
.review-form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.review-form-group textarea{min-height:100px;}
.btn-review-submit{background:linear-gradient(135deg,#8b0050,var(--cta));color:#fff;font-family:'Cinzel',serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:0.85rem 2rem;border:none;cursor:pointer;transition:all 0.3s;clip-path:polygon(5px 0%,100% 0%,calc(100% - 5px) 100%,0% 100%);}
.btn-review-submit:hover{transform:translateY(-2px);box-shadow:0 4px 15px rgba(196,30,138,0.3);}
.review-success-msg{display:none;background:rgba(37,211,102,0.1);border:1px solid #25d366;color:#25d366;font-family:'Cinzel',serif;font-size:0.75rem;letter-spacing:0.08em;padding:0.8rem 1rem;margin-bottom:1rem;}
@media(max-width:768px){
.product-page{grid-template-columns:1fr;padding:6rem 1rem 2rem;}
.product-gallery{position:static;}
.related-grid{grid-template-columns:repeat(2,1fr);}
.reviews-grid{grid-template-columns:1fr;}
.review-form-row{grid-template-columns:1fr;}
.breadcrumb{padding:6rem 1rem 0;}
.related-section,.reviews-section{padding-left:1rem;padding-right:1rem;}
}
</style>
<div class="breadcrumb">
<a href="/">Início</a><span class="breadcrumb-sep">✦</span>
<a href="/collections/all">Arsenal</a><span class="breadcrumb-sep">✦</span>
<span>{{ product.title }}</span>
</div>
<div class="product-page">
<div class="product-gallery">
<div class="product-main-image">
<div class="gallery-nav prev" onclick="galleryNav(-1)">‹</div>
<img id="main-product-image" src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title }}">
<div class="gallery-nav next" onclick="galleryNav(1)">›</div>
<div id="gallery-counter" class="gallery-counter">1 / {{ product.images.size }}</div>
</div>
<div class="product-thumbs">
{% for image in product.images %}
<div class="product-thumb{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" onclick="goToImage({{ forloop.index0 }})">
<img src="{{ image | img_url: '120x120' }}" alt="{{ image.alt | escape }}">
</div>
{% endfor %}
</div>
</div>
<div class="product-info">
<h1 class="product-info-title">{{ product.title }}</h1>
<div id="product-rating-inline" class="product-rating-inline"></div>
<div id="variant-price" class="product-info-price">R$ {{ current_variant.price | money_without_currency }}</div>
<form action="/cart/add" method="post" enctype="multipart/form-data">
{% unless product.has_only_default_variant %}
{% for option in product.options_with_values %}
<div>
<span class="variant-label">{{ option.name }}</span>
<div class="variant-options">
{% for value in option.values %}
<div class="variant-option{% if forloop.first %} active{% endif %}" data-value="{{ value }}">{{ value }}</div>
{% endfor %}
</div>
</div>
{% endfor %}
{% endunless %}
<select id="variant-select" name="id" style="display:none;">
{% for variant in product.variants %}
<option value="{{ variant.id }}" data-price="{{ variant.price | money_without_currency }}" data-image="{% if variant.image %}{{ variant.image | img_url: '800x800' }}{% endif %}" data-image-index="{{ variant.image.position | minus: 1 }}"{% if variant == current_variant %} selected{% endif %}>
{{ variant.title }} - R$ {{ variant.price | money_without_currency }}
</option>
{% endfor %}
</select>
<div class="frete-bar"><span>✦ FRETE GRÁTIS ACIMA DE R$50</span></div>
<div class="delivery-estimate" id="delivery-estimate">
<div class="delivery-icon">🚚</div>
<div class="delivery-info">
<span class="delivery-label">ESTIMATIVA DE ENTREGA</span>
<span class="delivery-date" id="delivery-date-text">Calculando...</span>
</div>
</div>
<button type="submit" class="product-add-btn">INVOCAR PARA MEU ARSENAL</button>
</form>
<a href="https://wa.me/5513991234567?text=Olá,%20quero%20saber%20mais%20sobre%20{{ product.title | url_encode }}" target="_blank" class="btn-wp">

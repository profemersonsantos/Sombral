<div class="product-guarantees">
<span>✓ Entrega garantida</span>
<span>✓ Garantia de 7 dias</span>
<span>✓ Pagamento seguro</span>
</div>
<div class="product-desc">{{ product.description }}</div>
</div>
</div>
{% assign related_collection = product.collections | first %}
{% if related_collection %}
{% assign related_products = related_collection.products | where: 'available', true %}
{% assign related_count = 0 %}
{% for p in related_products %}
{% unless p.id == product.id %}
{% assign related_count = related_count | plus: 1 %}
{% endunless %}
{% endfor %}
{% endif %}
{% if related_count > 0 %}
<div class="related-section">
<div class="related-title">✦ VOCÊ TAMBÉM PODE INVOCAR</div>
<div class="related-grid">
{% assign shown = 0 %}
{% for p in related_products %}
{% unless p.id == product.id %}
{% if shown < 4 %}
<a href="{{ p.url }}" class="related-card">
<div class="related-card-img">
<img src="{{ p.featured_image | img_url: '400x400' }}" alt="{{ p.title }}">
</div>
<div class="related-card-info">
<div class="related-card-title">{{ p.title }}</div>
<div class="related-card-price">R$ {{ p.price | money_without_currency }}</div>
</div>
<div class="related-card-btn">INVOCAR</div>
</a>
{% assign shown = shown | plus: 1 %}
{% endif %}
{% endunless %}
{% endfor %}
</div>
</div>
{% endif %}
<div class="reviews-section">
<div id="reviews-top" class="reviews-top"></div>
<div id="reviews-title-line" class="reviews-title-line"></div>
<div id="reviews-grid" class="reviews-grid"></div>
<div class="reviews-nav">
<button class="rev-btn" id="rev-prev" onclick="prevPage()">‹</button>
<div id="rev-info" class="rev-info"></div>
<button class="rev-btn" id="rev-next" onclick="nextPage()">›</button>
<button class="rev-ver-todas" onclick="viewAllReviews()">Ver todas</button>
</div>
<div class="review-form-section">
<div class="review-form-title">✦ DEIXE SUA EXPERIÊNCIA</div>
<div id="review-success" class="review-success-msg">Obrigado! Sua avaliação está sendo analisada pelas Sombras.</div>
<div class="star-picker">
<input type="radio" name="stars" value="5" id="s5"><label for="s5">★</label>
<input type="radio" name="stars" value="4" id="s4"><label for="s4">★</label>
<input type="radio" name="stars" value="3" id="s3"><label for="s3">★</label>
<input type="radio" name="stars" value="2" id="s2"><label for="s2">★</label>
<input type="radio" name="stars" value="1" id="s1"><label for="s1">★</label>
</div>
<div class="review-form-row">
<div class="review-form-group">
<label>Nome</label>
<input type="text" id="review-name" placeholder="Seu nome" required>
</div>
<div class="review-form-group">
<label>Cidade</label>
<input type="text" id="review-city" placeholder="Sua cidade">
</div>
</div>
<div class="review-form-group">
<label>Sua experiência</label>
<textarea id="review-text" placeholder="Conte sua experiência com este produto..." required></textarea>
</div>
<button class="btn-review-submit" onclick="submitReview()">ENVIAR AVALIAÇÃO</button>
</div>
</div>
<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js';
import { getFirestore, collection, getDocs, addDoc, query, where, orderBy, limit, serverTimestamp } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js';
const firebaseConfig = {
apiKey: "AIzaSyDKuO7r9UyN_jPqP8K0V8zFxJ3tN5zYx8Q",
authDomain: "sombral-reviews.firebaseapp.com",
projectId: "sombral-reviews",
storageBucket: "sombral-reviews.appspot.com",
messagingSenderId: "123456789012",
appId: "1:123456789012:web:abcdef1234567890abcdef"
};
const app = initializeApp(firebaseConfig);
const db = getFirestore(app);
const HANDLE = '{{ product.handle }}';
var allReviews = [];
var page = 0;
var perPage = 6;
window.renderGrid = function() {
var start = page * perPage;
var end = start + perPage;
var subset = allReviews.slice(start, end);
var html = subset.map(function(r) {
var stars = '★'.repeat(r.stars) + '☆'.repeat(5 - r.stars);
var cls = r.stars === 3 ? ' s3' : (r.stars === 4 ? ' s4' : '');
return '<div class="review-card"><div class="review-stars' + cls + '">' + stars + '</div><div class="review-text">' + r.text + '</div><div class="review-footer"><div><div class="review-name">' + r.name + '</div><div class="review-city">' + r.city + '</div></div>' + (r.verified ? '<div class="review-verified">✓ COMPRA VERIFICADA</div>' : '') + '</div></div>';
}).join('');
var gridEl = document.getElementById('reviews-grid');
if (gridEl) gridEl.innerHTML = html || '<p style="text-align:center;color:var(--text-muted);font-size:0.9rem;padding:2rem 0;">Ainda sem avaliações. Seja o primeiro!</p>';
var infoEl = document.getElementById('rev-info');
if (infoEl) infoEl.textContent = 'Mostrando ' + (start + 1) + '-' + Math.min(end, allReviews.length) + ' de ' + allReviews.length;
var prevBtn = document.getElementById('rev-prev');
var nextBtn = document.getElementById('rev-next');
if (prevBtn) prevBtn.disabled = page === 0;
if (nextBtn) nextBtn.disabled = end >= allReviews.length;
};
window.nextPage = function() { if ((page + 1) * perPage < allReviews.length) { page++; renderGrid(); } };
window.prevPage = function() { if (page > 0) { page--; renderGrid(); } };
window.viewAllReviews = function() { perPage = 9999; page = 0; renderGrid(); };
window.loadReviews = async function() {
try {
var q = query(collection(db, 'reviews'), where('productHandle', '==', HANDLE), where('status', '==', 'approved'), orderBy('createdAt', 'desc'), limit(100));
var snap = await getDocs(q);
allReviews = snap.docs.map(function(d) { return d.data(); });
} catch(e) { console.warn('[Reviews] Erro ao carregar:', e); }
if (!allReviews.length) return;
var total = allReviews.length;
var sum = 0;
var dist = {5:0, 4:0, 3:0};
allReviews.forEach(function(r) {
sum += r.stars;
if (r.stars >= 3) dist[r.stars]++;
});
var avg = sum / total;
dist[5] = Math.round(dist[5] / total * 100);
dist[4] = Math.round(dist[4] / total * 100);
dist[3] = Math.round(dist[3] / total * 100);
var rEl = document.getElementById('product-rating-inline');
if (rEl) rEl.innerHTML = '<span class="stars-inline">' + '★'.repeat(Math.round(avg)) + '☆'.repeat(5 - Math.round(avg)) + '</span><span class="rating-text">' + avg.toFixed(1) + ' · ' + total + ' avaliações</span>';
var topEl = document.getElementById('reviews-top');
if (topEl) {
var bars = [[5,'5 ★'],[4,'4 ★'],[3,'3 ★']].map(function(b) {
return '<div class="bar-row"><span class="bar-label">' + b[1] + '</span><div class="bar-track"><div class="bar-fill" style="width:' + (dist[b[0]] || 0) + '%"></div></div><span class="bar-pct">' + (dist[b[0]] || 0) + '%</span></div>';
}).join('');
topEl.innerHTML = '<div class="reviews-summary-box"><div class="reviews-avg-num">' + avg.toFixed(1) + '</div><div class="reviews-avg-stars">★★★★★</div><div class="reviews-total">' + total + ' avaliações</div></div><div class="reviews-bars">' + bars + '</div>';
}
var tEl = document.getElementById('reviews-title-line');
if (tEl) tEl.textContent = '✦ O que dizem as Sombras (' + total + ' avaliações recentes)';
renderGrid();
}
window.submitReview = async function() {
var starsEl = document.querySelector('input[name="stars"]:checked');
var name = document.getElementById('review-name').value.trim();
var city = document.getElementById('review-city').value.trim();
var text = document.getElementById('review-text').value.trim();
if (!starsEl) { alert('Selecione uma nota em estrelas.'); return; }
if (!name) { alert('Digite seu nome.'); return; }
if (text.length < 20) { alert('Escreva ao menos 20 caracteres.'); return; }
try {
await addDoc(collection(db, 'reviews'), {
productHandle: HANDLE,
stars: parseInt(starsEl.value),
name: name,
city: city || 'Brasil',
ctx: '',
text: text,
status: 'pending',
verified: false,
createdAt: serverTimestamp()
});
} catch(e) { console.warn('[Reviews] Erro ao salvar:', e); }
document.querySelectorAll('input[name="stars"]').forEach(function(i) { i.checked = false; });
document.getElementById('review-name').value = '';
document.getElementById('review-city').value = '';
document.getElementById('review-text').value = '';
var msg = document.getElementById('review-success');
msg.style.display = 'block';
setTimeout(function() { msg.style.display = 'none'; }, 4000);
};
// Delivery estimate
(function(){
var today=new Date();
var day=today.getDay();
var hour=today.getHours();
function addBD(date,days){var d=new Date(date);var a=0;while(a<days){d.setDate(d.getDate()+1);var w=d.getDay();if(w!==0&&w!==6)a++;}return d;}
var mn=5,mx=8;
if(hour>=14||day===0||day===6){mn++;mx++;}
var d1=addBD(today,mn);
var d2=addBD(today,mx);
var mo=['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
var s1=d1.getDate()+' '+mo[d1.getMonth()];
var s2=d2.getDate()+' '+mo[d2.getMonth()];
var el=document.getElementById('delivery-date-text');
if(el)el.textContent='Entre '+s1+' e '+s2;
})();
(function() {
var images = [{%- for image in product.images -%}{src:"{{ image | img_url: '800x800' }}",alt:"{{ image.alt | escape }}"}{% unless forloop.last %},{% endunless %}{%- endfor -%}];
var currentIndex = 0;
var mainImg = document.getElementById('main-product-image');
var counter = document.getElementById('gallery-counter');
var select = document.getElementById('variant-select');
var priceEl = document.getElementById('variant-price');
var btnPr = document.getElementById('btn-price');
window.goToImage = function(i) {
if (!images.length || i < 0 || i >= images.length) return;
currentIndex = i;
if (mainImg) { mainImg.style.opacity='0'; setTimeout(function(){mainImg.src=images[i].src;mainImg.alt=images[i].alt;mainImg.style.opacity='1';},180); }
if (counter) counter.textContent = (i + 1) + ' / ' + images.length;
document.querySelectorAll('.product-thumb').forEach(function(t){t.classList.toggle('active',parseInt(t.dataset.index)===i);});
};
window.galleryNav = function(dir) { goToImage((currentIndex + dir + images.length) % images.length); };
document.querySelectorAll('.variant-option').forEach(function(opt) {
opt.addEventListener('click', function() {
this.parentElement.querySelectorAll('.variant-option').forEach(function(s){s.classList.remove('active');});
this.classList.add('active');
var vals = [];
document.querySelectorAll('.variant-options').forEach(function(g){var a=g.querySelector('.variant-option.active');if(a)vals.push(a.dataset.value);});
var matched = null;
Array.from(select.options).forEach(function(o){if(o.text.trim()===vals.join(' / '))matched=o;});
if (matched) {
select.value = matched.value;
var price = matched.dataset.price;
if (price) { if(priceEl)priceEl.textContent='R$ '+price; if(btnPr)btnPr.textContent=price; }
var varImgSrc = matched.dataset.image;
if (varImgSrc && varImgSrc !== 'null' && varImgSrc !== '') {
var norm = function(u){return u?u.split('?')[0].replace(/_\d+x[\d]*\./,'.'):''};
var target = norm(varImgSrc);
var found = -1;
for (var i = 0; i < images.length; i++){if(norm(images[i].src)===target){found=i;break;}}
if (found >= 0) goToImage(found);
else { var idx=parseInt(matched.dataset.imageIndex); if(!isNaN(idx)&&idx>=0&&images[idx])goToImage(idx); }
}
}
});
});
})();
loadReviews();
</script>

    {stars:4,name:"Renata L.",city:"São Paulo, SP",ctx:"",text:"Produto de ótima qualidade. A bolsa de veludo é um detalhe que agrega muito. Tirei uma estrela porque esperava que as pedras viessem numeradas no guia."},
    {stars:5,name:"Diego S.",city:"Rio de Janeiro, RJ",ctx:"Paganismo nórdico",text:"Kit que uso em cerimônias de blót. As pedras têm o peso certo e a gravação é precisa. A obsidiana em especial tem uma energia que potencializa o ritual."},
    {stars:5,name:"Isabela T.",city:"São Paulo, SP",ctx:"",text:"As runas de quartzo são simplesmente lindas. A transparência das pedras com os símbolos gravados cria um efeito visual único na mesa de ritual."},
    {stars:5,name:"Roberta A.",city:"Florianópolis, SC",ctx:"",text:"Comprei para estudar e as pedras viraram minhas companheiras diárias. A bolsa de veludo aguenta bem o uso frequente. Kit que vale cada centavo."},
    {stars:4,name:"Eduardo M.",city:"São Paulo, SP",ctx:"",text:"Ótimo kit. Só faltou um pano de lançamento junto — para quem está começando, não sabe que precisa de um. As pedras em si são excelentes."}

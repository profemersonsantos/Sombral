{% assign current_variant = product.selected_or_first_available_variant %}

<style>
.product-page{display:grid;grid-template-columns:1fr 1fr;gap:3rem;max-width:1100px;margin:0 auto;padding:8rem 2rem 4rem;align-items:start;}
.product-gallery{position:sticky;top:7rem;}
.product-main-image{width:100%;aspect-ratio:1/1;max-height:500px;overflow:visible;border:none;background:transparent;display:flex;align-items:center;justify-content:center;position:relative;}
.product-main-image img{width:100%;height:100%;object-fit:contain;transition:opacity 0.3s ease;background:transparent;mix-blend-mode:multiply;}
.gallery-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);border:1px solid var(--accent);color:var(--gold);width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.2rem;z-index:10;transition:all 0.2s;}
.gallery-nav:hover{background:rgba(123,47,190,0.4);border-color:var(--gold);}
.gallery-nav.prev{left:8px;}.gallery-nav.next{right:8px;}
.gallery-counter{position:absolute;bottom:8px;right:10px;font-family:'Cinzel',serif;font-size:0.65rem;color:var(--text-muted);background:rgba(0,0,0,0.5);padding:2px 6px;}
.product-thumbs{display:flex;gap:0.5rem;margin-top:0.6rem;flex-wrap:wrap;}
.product-thumb{width:60px;height:60px;overflow:visible;border:1px solid var(--border);background:transparent;cursor:pointer;transition:all 0.2s;}
.product-thumb img{width:100%;height:100%;object-fit:contain;background:transparent;mix-blend-mode:multiply;}
.product-thumb.active{border-color:var(--accent);box-shadow:0 0 8px rgba(123,47,190,0.4);}
.product-thumb:hover{border-color:var(--gold);}
.breadcrumb{max-width:1100px;margin:0 auto;padding:7rem 2rem 0;font-size:0.8rem;color:var(--text-muted);font-family:'Cinzel',serif;letter-spacing:0.06em;}
.breadcrumb a{color:var(--text-muted);transition:color 0.2s;}.breadcrumb a:hover{color:var(--text);}
.breadcrumb-sep{margin:0 0.5rem;color:var(--accent);}
.product-info{display:flex;flex-direction:column;gap:1.2rem;}
.product-info-title{font-family:'Cinzel',serif;font-size:clamp(1.2rem,2.5vw,1.8rem);font-weight:700;line-height:1.3;}
.product-info-price{font-family:'Cinzel',serif;font-size:1.6rem;font-weight:900;color:var(--gold);}
.product-rating-inline{display:flex;align-items:center;gap:0.6rem;}
.stars-inline{color:var(--gold);font-size:0.9rem;letter-spacing:1px;}
.rating-text{font-family:'Cinzel',serif;font-size:0.72rem;color:var(--text-muted);letter-spacing:0.06em;}
.variant-label{display:block;font-family:'Cinzel',serif;font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.5rem;}
.variant-options{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;}
.variant-option{padding:0.5rem 1rem;background:var(--bg-card);border:1px solid var(--border);color:var(--text-muted);font-family:'Cinzel',serif;font-size:0.75rem;letter-spacing:0.06em;cursor:pointer;transition:all 0.2s;user-select:none;}
.variant-option:hover{border-color:var(--accent);color:var(--text);}
.variant-option.active{background:rgba(123,47,190,0.15);border-color:var(--accent);color:var(--text);}
.product-add-btn{width:100%;background:linear-gradient(135deg,#8b0050,var(--cta));color:#fff;font-family:'Cinzel',serif;font-size:0.85rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:1rem;border:none;cursor:pointer;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:all 0.3s;box-shadow:0 0 20px rgba(196,30,138,0.3);}
.product-add-btn:hover{transform:translateY(-2px);box-shadow:0 0 30px rgba(196,30,138,0.5);}
.btn-wp{display:flex;align-items:center;justify-content:center;gap:0.5rem;background:transparent;border:1px solid #25d366;color:#25d366;font-family:'Cinzel',serif;font-size:0.78rem;letter-spacing:0.1em;padding:0.8rem;text-decoration:none;transition:all 0.2s;}
.btn-wp:hover{background:rgba(37,211,102,0.1);}
.product-guarantees{display:flex;gap:1rem;flex-wrap:wrap;padding-top:1rem;border-top:1px solid var(--border);font-size:0.72rem;color:var(--text-muted);font-family:'Cinzel',serif;letter-spacing:0.05em;}
.product-desc{color:var(--text-muted);font-size:0.88rem;line-height:1.7;padding-top:1rem;border-top:1px solid var(--border);}

/* REVIEWS */
.reviews-section{max-width:1100px;margin:0 auto;padding:3rem 2rem 4rem;}
.reviews-top{display:flex;align-items:flex-start;gap:3rem;margin-bottom:2.5rem;flex-wrap:wrap;}
.reviews-summary-box{background:var(--bg-card);border:1px solid var(--border);padding:1.5rem 2rem;text-align:center;min-width:160px;}
.reviews-avg-num{font-family:'Cinzel',serif;font-size:3rem;font-weight:900;color:var(--gold);line-height:1;}
.reviews-avg-stars{color:var(--gold);font-size:1.1rem;letter-spacing:2px;margin:0.4rem 0;}
.reviews-total{font-size:0.72rem;color:var(--text-muted);font-family:'Cinzel',serif;}
.reviews-bars{flex:1;min-width:200px;display:flex;flex-direction:column;gap:0.5rem;justify-content:center;}
.bar-row{display:flex;align-items:center;gap:0.7rem;}
.bar-label{font-family:'Cinzel',serif;font-size:0.72rem;color:var(--text-muted);min-width:48px;text-align:right;}
.bar-track{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden;}
.bar-fill{height:100%;background:var(--gold);border-radius:3px;}
.bar-pct{font-size:0.68rem;color:var(--text-muted);min-width:30px;}
.reviews-title-line{font-family:'Cinzel',serif;font-size:1rem;font-weight:700;letter-spacing:0.1em;color:var(--text);margin-bottom:1.5rem;padding-bottom:0.8rem;border-bottom:1px solid var(--border);}
.reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.2rem;margin-bottom:1.5rem;}
.review-card{background:var(--bg-card);border:1px solid var(--border);border-left:3px solid var(--accent);padding:1.4rem;display:flex;flex-direction:column;gap:0.7rem;transition:border-color 0.2s;}
.review-card:hover{border-left-color:var(--cta);}
.review-stars{color:var(--gold);font-size:0.82rem;letter-spacing:2px;}
.review-stars.s3{color:#b8860b;}.review-stars.s4{color:#c9a030;}
.review-text{font-family:'Crimson Text',serif;font-style:italic;font-size:0.93rem;color:var(--text-muted);line-height:1.65;flex:1;}
.review-footer{display:flex;justify-content:space-between;align-items:center;padding-top:0.7rem;border-top:1px solid var(--border);}
.review-name{font-family:'Cinzel',serif;font-size:0.72rem;font-weight:700;letter-spacing:0.08em;}
.review-city{font-size:0.68rem;color:var(--text-muted);margin-top:0.1rem;}
.review-verified{font-size:0.62rem;color:#25d366;font-family:'Cinzel',serif;}

/* NAV REVIEWS */
.reviews-nav{display:flex;align-items:center;justify-content:center;gap:0.8rem;margin-bottom:2rem;flex-wrap:wrap;}
.rev-btn{background:var(--bg-card);border:1px solid var(--accent);color:var(--gold);width:42px;height:42px;font-size:1.3rem;cursor:pointer;transition:all 0.2s;font-family:serif;display:flex;align-items:center;justify-content:center;}
.rev-btn:hover:not(:disabled){background:rgba(123,47,190,0.2);}
.rev-btn:disabled{opacity:0.3;cursor:default;}
.rev-info{font-family:'Cinzel',serif;font-size:0.72rem;color:var(--text-muted);letter-spacing:0.08em;text-align:center;min-width:160px;}
.rev-ver-todas{background:transparent;border:1px solid var(--border);color:var(--text-muted);font-family:'Cinzel',serif;font-size:0.68rem;letter-spacing:0.08em;padding:0.5rem 1rem;cursor:pointer;transition:all 0.2s;}
.rev-ver-todas:hover{border-color:var(--accent);color:var(--text);}

/* FORM AVALIACAO */
.review-form-section{background:var(--bg-card);border:1px solid var(--border);padding:2rem;margin-top:0.5rem;}
.review-form-title{font-family:'Cinzel',serif;font-size:0.95rem;font-weight:700;letter-spacing:0.08em;margin-bottom:1.5rem;}
.star-picker{display:flex;gap:0.4rem;margin-bottom:1.2rem;flex-direction:row-reverse;justify-content:flex-end;}
.star-picker input{display:none;}
.star-picker label{font-size:1.8rem;color:var(--border);cursor:pointer;transition:color 0.15s;line-height:1;}
.star-picker label:hover,.star-picker label:hover ~ label,.star-picker input:checked ~ label{color:var(--gold);}
.review-form-group{margin-bottom:1rem;}
.review-form-group label{display:block;font-family:'Cinzel',serif;font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.4rem;}
.review-form-group input,.review-form-group textarea{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:'Inter',sans-serif;font-size:0.88rem;padding:0.7rem 1rem;outline:none;transition:border-color 0.2s;resize:vertical;}
.review-form-group input:focus,.review-form-group textarea:focus{border-color:var(--accent);}
.review-form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.review-form-group textarea{min-height:100px;}
.btn-review-submit{background:linear-gradient(135deg,#8b0050,var(--cta));color:#fff;font-family:'Cinzel',serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:0.85rem 2rem;border:none;cursor:pointer;transition:all 0.3s;clip-path:polygon(5px 0%,100% 0%,calc(100% - 5px) 100%,0% 100%);}
.btn-review-submit:hover{transform:translateY(-1px);box-shadow:0 0 20px rgba(196,30,138,0.4);}
.review-success{display:none;background:rgba(37,211,102,0.1);border:1px solid #25d366;color:#25d366;font-family:'Cinzel',serif;font-size:0.8rem;padding:1rem;letter-spacing:0.06em;margin-top:1rem;}

@media(max-width:768px){
  .product-page{grid-template-columns:1fr;padding:6rem 1.2rem 3rem;gap:1.5rem;}
  .product-gallery{position:static;}
  .breadcrumb{padding:5.5rem 1.2rem 0;}
  .reviews-grid{grid-template-columns:1fr;}
  .review-form-row{grid-template-columns:1fr;}
  .reviews-top{gap:1.5rem;}
}
</style>

<nav class="breadcrumb">
  <a href="/">Início</a><span class="breadcrumb-sep">›</span>
  <a href="/collections/all">Catálogo</a><span class="breadcrumb-sep">›</span>
  <span>{{ product.title }}</span>
</nav>

<div class="product-page">
  <div class="product-gallery">
    <div class="product-main-image" id="main-gallery">
      {%- if product.images.size > 0 -%}
        <img id="main-product-image" src="{{ product.images[0] | img_url: '800x800' }}" alt="{{ product.title | escape }}">
        {%- if product.images.size > 1 -%}
          <button class="gallery-nav prev" onclick="galleryNav(-1)">&#8249;</button>
          <button class="gallery-nav next" onclick="galleryNav(1)">&#8250;</button>
          <div class="gallery-counter" id="gallery-counter">1 / {{ product.images.size }}</div>
        {%- endif -%}
      {%- else -%}
        <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;min-height:300px;">
          <span style="font-size:4rem;color:var(--accent);opacity:0.3;">✦</span>
        </div>
      {%- endif -%}
    </div>
    {%- if product.images.size > 1 -%}
      <div class="product-thumbs">
        {%- for image in product.images -%}
          <div class="product-thumb {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" onclick="goToImage({{ forloop.index0 }})">
            <img src="{{ image | img_url: '120x120' }}" alt="">
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product-info">
    <h1 class="product-info-title">{{ product.title }}</h1>
    <div class="product-rating-inline" id="product-rating-inline"></div>
    <div class="product-info-price" id="variant-price">R$ {{ current_variant.price | money_without_currency }}</div>
    <form action="/cart/add" method="post" enctype="multipart/form-data">
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <span class="variant-label">{{ option.name }}</span>
          <div class="variant-options">
            {%- for value in option.values -%}
              <div class="variant-option {% if forloop.first %}active{% endif %}" data-value="{{ value }}">{{ value }}</div>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      {%- endunless -%}
      <select name="id" id="variant-select" style="display:none;">
        {%- for variant in product.variants -%}
          <option value="{{ variant.id }}" data-price="{{ variant.price | money_without_currency }}" data-image="{{ variant.image | img_url: '800x800' }}" data-image-index="{{ variant.image.position | minus: 1 }}" {% if variant == current_variant %}selected{% endif %}>{{ variant.title }}</option>
        {%- endfor -%}
      </select>
      <button type="submit" class="product-add-btn">Invocar — R$ <span id="btn-price">{{ current_variant.price | money_without_currency }}</span></button>
    </form>
    <a href="https://wa.me/5519989085731" class="btn-wp" target="_blank">💬 Dúvidas? Fale pelo WhatsApp</a>
    <div class="product-guarantees">
      <span>🔒 Compra Segura</span>
      <span>📦 Frete Grátis acima de R$79,90</span>
      <span>↩️ Garantia 7 Dias</span>
    </div>
    <div class="product-desc">{{ product.description }}</div>
  </div>
</div>

<div class="reviews-section">
  <div class="reviews-top" id="reviews-top"></div>
  <p class="reviews-title-line" id="reviews-title-line"></p>
  <div class="reviews-grid" id="reviews-grid"></div>
  <div class="reviews-nav" id="reviews-nav"></div>

  <div class="review-form-section">
    <p class="review-form-title">✦ Deixe sua avaliação</p>
    <div class="star-picker" id="star-picker">
      <input type="radio" id="s5" name="stars" value="5"><label for="s5">★</label>
      <input type="radio" id="s4" name="stars" value="4"><label for="s4">★</label>
      <input type="radio" id="s3" name="stars" value="3"><label for="s3">★</label>
      <input type="radio" id="s2" name="stars" value="2"><label for="s2">★</label>
      <input type="radio" id="s1" name="stars" value="1"><label for="s1">★</label>
    </div>
    <div class="review-form-row">
      <div class="review-form-group"><label>Seu nome</label><input type="text" id="review-name" placeholder="Ex: Maria S." maxlength="60"></div>
      <div class="review-form-group"><label>Cidade e Estado</label><input type="text" id="review-city" placeholder="Ex: São Paulo, SP" maxlength="60"></div>
    </div>
    <div class="review-form-group"><label>Sua avaliação</label><textarea id="review-text" placeholder="Conte sua experiência com o produto..." maxlength="500"></textarea></div>
    <button class="btn-review-submit" onclick="submitReview()">Enviar Avaliação</button>
    <div class="review-success" id="review-success">✦ Avaliação enviada! Obrigado por compartilhar sua experiência.</div>
  </div>
</div>

<script>
(function(){
  // ---- GALERIA ----
  var images=[{%- for image in product.images -%}{src:"{{ image | img_url: '800x800' }}",alt:"{{ image.alt | escape }}"}{% unless forloop.last %},{% endunless %}{%- endfor -%}];
  var currentIndex=0;
  var mainImg=document.getElementById('main-product-image');
  var counter=document.getElementById('gallery-counter');
  var select=document.getElementById('variant-select');
  var priceEl=document.getElementById('variant-price');
  var btnPr=document.getElementById('btn-price');

  window.goToImage=function(i){
    if(!images.length||i<0||i>=images.length)return;
    currentIndex=i;
    if(mainImg){mainImg.style.opacity='0';setTimeout(function(){mainImg.src=images[i].src;mainImg.alt=images[i].alt;mainImg.style.opacity='1';},180);}
    if(counter)counter.textContent=(i+1)+' / '+images.length;
    document.querySelectorAll('.product-thumb').forEach(function(t){t.classList.toggle('active',parseInt(t.dataset.index)===i);});
  };
  window.galleryNav=function(dir){goToImage((currentIndex+dir+images.length)%images.length);};

  // ---- VARIANTES ----
  document.querySelectorAll('.variant-option').forEach(function(opt){
    opt.addEventListener('click',function(){
      this.parentElement.querySelectorAll('.variant-option').forEach(function(s){s.classList.remove('active');});
      this.classList.add('active');
      var vals=[];
      document.querySelectorAll('.variant-options').forEach(function(g){var a=g.querySelector('.variant-option.active');if(a)vals.push(a.dataset.value);});
      var matched=null;
      Array.from(select.options).forEach(function(o){if(o.text.trim()===vals.join(' / '))matched=o;});
      if(matched){
        select.value=matched.value;
        var price=matched.dataset.price;
        if(price){if(priceEl)priceEl.textContent='R$ '+price;if(btnPr)btnPr.textContent=price;}
        var varImgSrc=matched.dataset.image;
        if(varImgSrc&&varImgSrc!=='null'&&varImgSrc!==''){
          var norm=function(u){return u?u.split('?')[0].replace(/_\d+x[\d]*\./,'.'):''};
          var target=norm(varImgSrc);
          var found=-1;
          for(var i=0;i<images.length;i++){if(norm(images[i].src)===target){found=i;break;}}
          if(found>=0)goToImage(found);
          else{var idx=parseInt(matched.dataset.imageIndex);if(!isNaN(idx)&&idx>=0&&images[idx])goToImage(idx);}
        }
      }
    });
  });

  // ---- DADOS DOS REVIEWS ----
  var handle="{{ product.handle }}";
  var PER_PAGE=3;
  var currentPage=0;
  var allData={};

  allData["sombral-baralho-tarot-das-trevas-goeticas"]={avg:4.8,total:31,dist:{5:77,4:13,3:10},reviews:[
    {stars:5,name:"Natália R.",city:"São Paulo, SP",ctx:"Tarot há 3 anos",text:"Nunca pensei que um baralho físico pudesse ter tanta presença. As cartas chegaram embaladas com cuidado e o papel é diferente — gramatura real. Já fiz três leituras e as ilustrações dark elevam tudo."},
    {stars:5,name:"Marcelo F.",city:"Belo Horizonte, MG",ctx:"",text:"Comprei com certo receio por ser online, mas chegou exatamente como na foto. A caixa magnética é um luxo. O guia em português é direto e prático."},
    {stars:4,name:"Camila T.",city:"Curitiba, PR",ctx:"",text:"Muito bonito e bem acabado. Só achei o guia um pouco curto para iniciantes. Mas o baralho em si é incrível, recomendo."},
    {stars:5,name:"Jéssica M.",city:"Rio de Janeiro, RJ",ctx:"Colecionadora",text:"Tenho mais de 10 baralhos e esse é o que mais uso. A arte goética tem uma densidade que outras ilustrações não têm. Chegou em 8 dias, bem antes do prazo."},
    {stars:3,name:"Ricardo P.",city:"Manaus, AM",ctx:"",text:"O baralho é bonito, mas esperava que as 78 cartas fossem todas ilustradas individualmente. Algumas são variações. Ainda assim vale pelo preço e pela qualidade do papel."},
    {stars:5,name:"Aline G.",city:"Porto Alegre, RS",ctx:"",text:"Presente pra minha irmã que pratica tarot há anos. Ela ficou sem palavras. Disse que é o baralho mais bonito que já viu. Embalagem impecável."},
    {stars:5,name:"Thiago B.",city:"Fortaleza, CE",ctx:"Leitor profissional",text:"Uso em consultas profissionais. Os clientes ficam impressionados só de ver o baralho. O acabamento fosco não deixa marcas de dedos."},
    {stars:4,name:"Fernanda L.",city:"Recife, PE",ctx:"",text:"Arte incrível e papel resistente. Só esperava uma sacola de pano junto. A caixa magnética compensa."},
    {stars:5,name:"Bruno A.",city:"Salvador, BA",ctx:"Esotérico há 5 anos",text:"Comprei para estudo e uso diário. A simbologia goética nas ilustrações é precisa — não é apenas estética, tem conteúdo de verdade."},
    {stars:5,name:"Daniela C.",city:"São Paulo, SP",ctx:"",text:"Terceira compra na SOMBRAL. Cada vez que abro essa caixa parece ritual novo. As cartas deslizam perfeitamente, não grudam."},
    {stars:5,name:"Rafael M.",city:"Florianópolis, SC",ctx:"Tarot há 1 ano",text:"Comecei no tarot há um ano e esse baralho me fez levar a prática mais a sério. A arte é densa e cada carta provoca reflexão."},
    {stars:3,name:"Mariana K.",city:"Campinas, SP",ctx:"",text:"Gostei bastante do visual mas algumas cartas vieram com bordas levemente irregulares. Não compromete o uso mas para um produto premium esperava perfeição."},
    {stars:5,name:"Leonardo S.",city:"Goiânia, GO",ctx:"",text:"O baralho chegou em 10 dias e a embalagem estava impecável. A caixa magnética tem acabamento que parece premium de verdade. Muito satisfeito."},
    {stars:5,name:"Patrícia V.",city:"Curitiba, PR",ctx:"Wicca",text:"Uso em rituais de adivinhação e as cartas têm uma energia muito especial. A arte goética parece intencional em cada símbolo. Recomendo para praticantes sérios."},
    {stars:4,name:"Gustavo R.",city:"São Paulo, SP",ctx:"",text:"Baralho muito bem produzido. Papel premium de verdade. Só achei o guia um pouco genérico — poderia ter interpretações mais profundas. Mas as cartas compensam tudo."},
    {stars:5,name:"Amanda F.",city:"Rio de Janeiro, RJ",ctx:"",text:"Comprei para estudar e já li o baralho inteiro duas vezes. As ilustrações têm camadas de significado que você vai descobrindo aos poucos. Arte excepcional."},
    {stars:5,name:"Carlos M.",city:"Brasília, DF",ctx:"Ocultismo",text:"Para quem pratica magia goética, esse baralho é uma ferramenta séria. Os arcanos maiores têm referências precisas às Chaves de Salomão. Impressionante."},
    {stars:4,name:"Juliana H.",city:"Porto Alegre, RS",ctx:"",text:"Muito bonito e resistente. Já lavei acidentalmente uma carta com água e ela aguentou — papel realmente resistente. Uma estrela a menos pela demora na entrega."},
    {stars:5,name:"Rodrigo L.",city:"São Paulo, SP",ctx:"",text:"Presente que virou meu baralho favorito mesmo não sendo meu. Minha namorada me deu como presente e eu tomei emprestado para nunca mais devolver."},
    {stars:5,name:"Bianca T.",city:"Recife, PE",ctx:"Tarotista",text:"Trabalho lendo tarot há 3 anos e esse é o baralho que mais complica meus clientes no bom sentido. As imagens provocam respostas que outros baralhos não provocam."},
    {stars:5,name:"Felipe A.",city:"Natal, RN",ctx:"",text:"Chegou em 7 dias, embalagem com papel de seda preto e fita. Parecia um presente luxuoso mesmo sem ter pedido embalagem especial. As cartas são excelentes."},
    {stars:3,name:"Vanessa C.",city:"São Paulo, SP",ctx:"",text:"O baralho é bonito mas achei que algumas cartas dos arcanos menores são muito parecidas entre si visualmente. Para leituras rápidas pode confundir. Para quem já tem experiência, funciona bem."},
    {stars:5,name:"Eduardo P.",city:"Belo Horizonte, MG",ctx:"",text:"Comprei para colecionar e acabei usando. A textura das cartas é diferente — não escorrega, não gruda. Qualidade que você sente antes mesmo de ver."},
    {stars:5,name:"Luciana R.",city:"Florianópolis, SC",ctx:"",text:"Uso em práticas de meditação focada em cada arcano. A arte goética convida para um nível de concentração que baralhos coloridos e alegres não provocam."},
    {stars:4,name:"Marcos V.",city:"São Paulo, SP",ctx:"",text:"Excelente produto. Tirei uma estrela porque o guia traduzido tem algumas expressões que ficaram estranhas em português. As cartas em si são impecáveis."},
    {stars:5,name:"Isabela M.",city:"Curitiba, PR",ctx:"",text:"Minha primeira compra aqui e fiquei impressionada com a qualidade. A caixa magnética fechou com um clique que parece premium de verdade. Voltarei a comprar."},
    {stars:5,name:"Renato F.",city:"Porto Alegre, RS",ctx:"Leitor há 8 anos",text:"Em 8 anos lendo tarot nunca vi uma produção tão cuidadosa num preço acessível. Cada carta parece ter sido pensada individualmente. Recomendo sem reservas."},

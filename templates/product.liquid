{% assign current_variant = product.selected_or_first_available_variant %}

<style>
.product-page {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  max-width: 1100px;
  margin: 0 auto;
  padding: 8rem 2rem 4rem;
  align-items: start;
}

.product-gallery {
  position: sticky;
  top: 7rem;
}

.product-main-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  max-height: 480px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-main-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.3s ease;
}

.breadcrumb {
  max-width: 1100px;
  margin: 0 auto;
  padding: 7rem 2rem 0;
  font-size: 0.8rem;
  color: var(--text-muted);
  font-family: 'Cinzel', serif;
  letter-spacing: 0.06em;
}

.breadcrumb a { color: var(--text-muted); transition: color 0.2s; }
.breadcrumb a:hover { color: var(--text); }
.breadcrumb-sep { margin: 0 0.5rem; color: var(--accent); }

.product-info { display: flex; flex-direction: column; gap: 1.2rem; }

.product-info-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.2rem, 2.5vw, 1.8rem);
  font-weight: 700;
  line-height: 1.3;
  color: var(--text);
}

.product-info-price {
  font-family: 'Cinzel', serif;
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--gold);
}

.variant-label {
  display: block;
  font-family: 'Cinzel', serif;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.variant-options {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.variant-option {
  padding: 0.5rem 1rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-family: 'Cinzel', serif;
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: all 0.2s;
  user-select: none;
}

.variant-option:hover {
  border-color: var(--accent);
  color: var(--text);
}

.variant-option.active {
  background: rgba(123,47,190,0.15);
  border-color: var(--accent);
  color: var(--text);
  box-shadow: 0 0 10px rgba(123,47,190,0.2);
}

.product-add-btn {
  width: 100%;
  background: linear-gradient(135deg, #8b0050, var(--cta));
  color: #fff;
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 1rem;
  border: none;
  cursor: pointer;
  clip-path: polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);
  transition: all 0.3s;
  box-shadow: 0 0 20px rgba(196,30,138,0.3);
}

.product-add-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 30px rgba(196,30,138,0.5);
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  background: transparent;
  border: 1px solid #25d366;
  color: #25d366;
  font-family: 'Cinzel', serif;
  font-size: 0.78rem;
  letter-spacing: 0.1em;
  padding: 0.8rem;
  text-decoration: none;
  transition: all 0.2s;
}

.btn-outline:hover {
  background: rgba(37,211,102,0.1);
}

.product-guarantees {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
  font-size: 0.72rem;
  color: var(--text-muted);
  font-family: 'Cinzel', serif;
  letter-spacing: 0.05em;
}

.product-desc {
  color: var(--text-muted);
  font-size: 0.88rem;
  line-height: 1.7;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}

@media (max-width: 768px) {
  .product-page {
    grid-template-columns: 1fr;
    padding: 6rem 1.2rem 3rem;
    gap: 1.5rem;
  }
  .product-gallery { position: static; }
  .breadcrumb { padding: 5.5rem 1.2rem 0; }
}
</style>

<nav class="breadcrumb">
  <a href="/">Início</a>
  <span class="breadcrumb-sep">›</span>
  <a href="/collections/all">Catálogo</a>
  <span class="breadcrumb-sep">›</span>
  <span>{{ product.title }}</span>
</nav>

<div class="product-page">

  <!-- GALERIA -->
  <div class="product-gallery">
    <div class="product-main-image">
      {%- if product.featured_image -%}
        <img id="main-product-image"
             src="{{ current_variant.image | default: product.featured_image | img_url: '800x800', crop: 'center' }}"
             alt="{{ product.title | escape }}">
      {%- else -%}
        <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;min-height:300px;">
          <span style="font-size:4rem;color:var(--accent);opacity:0.3;">✦</span>
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- INFO -->
  <div class="product-info">

    <h1 class="product-info-title">{{ product.title }}</h1>

    <div class="product-info-price" id="variant-price">
      R$ {{ current_variant.price | money_without_currency }}
    </div>

    <form action="/cart/add" method="post" enctype="multipart/form-data">
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <span class="variant-label">{{ option.name }}</span>
          <div class="variant-options">
            {%- for value in option.values -%}
              <div class="variant-option {% if forloop.first %}active{% endif %}"
                   data-value="{{ value }}">{{ value }}</div>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <select name="id" id="variant-select" style="display:none;">
        {%- for variant in product.variants -%}
          <option
            value="{{ variant.id }}"
            data-price="{{ variant.price | money_without_currency }}"
            data-image="{{ variant.image | img_url: '800x800', crop: 'center' }}"
            {% if variant == current_variant %}selected{% endif %}>
            {{ variant.title }}
          </option>
        {%- endfor -%}
      </select>

      <button type="submit" class="product-add-btn" id="add-to-cart-btn">
        Invocar — R$ <span id="btn-price">{{ current_variant.price | money_without_currency }}</span>
      </button>
    </form>

    <a href="https://wa.me/5519989085731" class="btn-outline" target="_blank">
      💬 Dúvidas? Fale pelo WhatsApp
    </a>

    <div class="product-guarantees">
      <span>🔒 Compra Segura</span>
      <span>📦 Frete Grátis acima de R$79,90</span>
      <span>↩️ Garantia 7 Dias</span>
    </div>

    <div class="product-desc">{{ product.description }}</div>

  </div>
</div>

<script>
(function(){
  var select  = document.getElementById('variant-select');
  var mainImg = document.getElementById('main-product-image');
  var priceEl = document.getElementById('variant-price');
  var btnPr   = document.getElementById('btn-price');

  document.querySelectorAll('.variant-option').forEach(function(opt){
    opt.addEventListener('click', function(){
      this.parentElement.querySelectorAll('.variant-option').forEach(function(s){ s.classList.remove('active'); });
      this.classList.add('active');

      var vals = [];
      document.querySelectorAll('.variant-options').forEach(function(g){
        var a = g.querySelector('.variant-option.active');
        if(a) vals.push(a.dataset.value);
      });

      var matched = null;
      Array.from(select.options).forEach(function(o){
        if(o.text.trim() === vals.join(' / ')) matched = o;
      });

      if(matched){
        select.value = matched.value;
        var price = matched.dataset.price;
        if(price){ if(priceEl) priceEl.textContent='R$ '+price; if(btnPr) btnPr.textContent=price; }
        var img = matched.dataset.image;
        if(mainImg && img && img!=='null' && img!==''){
          mainImg.style.opacity='0';
          setTimeout(function(){ mainImg.src=img; mainImg.style.opacity='1'; },200);
        }
      }
    });
  });
})();
</script>

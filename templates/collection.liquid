<style>
.collection-page {
max-width: 1280px;
margin: 0 auto;
padding: 8rem 2rem 5rem;
}
.collection-header {
text-align: center;
margin-bottom: 3rem;
padding-bottom: 2rem;
border-bottom: 1px solid var(--border);
}
.collection-eyebrow {
font-family: 'Crimson Text', serif;
font-style: italic;
color: var(--gold);
font-size: 0.95rem;
letter-spacing: 0.15em;
margin-bottom: 0.5rem;
}
.collection-title {
font-family: 'Cinzel', serif;
font-size: clamp(1.8rem, 4vw, 3rem);
font-weight: 700;
background: linear-gradient(135deg, #E8E0F0 0%, #c9a84c 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
margin-bottom: 1rem;
}
.collection-desc {
color: var(--text-muted);
font-size: 0.95rem;
max-width: 520px;
margin: 0 auto;
font-family: 'Crimson Text', serif;
font-style: italic;
}
.collection-count {
font-family: 'Cinzel', serif;
font-size: 0.72rem;
color: var(--text-muted);
letter-spacing: 0.1em;
margin-top: 0.8rem;
}
.col-products-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
gap: 1.5rem;
}
.col-product-card {
background: var(--bg-card);
border: 1px solid var(--border);
overflow: hidden;
transition: all 0.3s ease;
position: relative;
text-decoration: none;
color: inherit;
display: block;
}
.col-product-card:hover {
border-color: var(--accent);
transform: translateY(-4px);
box-shadow: 0 8px 30px rgba(123,47,190,0.2);
}
.col-product-image {
aspect-ratio: 1;
overflow: hidden;
background: var(--bg-card);
display: flex;
align-items: center;
justify-content: center;
}
.col-product-image img {
width: 100%;
height: 100%;
object-fit: cover;
transition: transform 0.4s ease;
}
.col-product-card:hover .col-product-image img { transform: scale(1.05); }
.col-product-placeholder {
font-size: 3rem;
color: var(--accent);
opacity: 0.4;
}
.col-product-info {
padding: 1.2rem;
display: flex;
flex-direction: column;
gap: 0.7rem;
}
.col-product-title {
font-family: 'Cinzel', serif;
font-size: 0.85rem;
font-weight: 600;
letter-spacing: 0.05em;
line-height: 1.4;
color: var(--text);
}
.col-product-price {
display: flex;
align-items: center;
gap: 0.6rem;
}
.col-price-old {
color: var(--text-muted);
text-decoration: line-through;
font-size: 0.8rem;
}
.col-price-current {
color: var(--gold);
font-family: 'Cinzel', serif;
font-weight: 700;
font-size: 1rem;
}
.col-btn-invocar {
display: block;
background: linear-gradient(135deg, #8b0050, var(--cta));
color: #fff;
font-family: 'Cinzel', serif;
font-size: 0.78rem;
font-weight: 700;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 0.65rem 1.4rem;
border: none;
cursor: pointer;
clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
transition: all 0.3s ease;
box-shadow: 0 0 12px rgba(196,30,138,0.3);
text-align: center;
text-decoration: none;
}
.col-btn-invocar:hover {
box-shadow: 0 0 22px rgba(196,30,138,0.5);
}
.collection-empty {
text-align: center;
padding: 5rem 2rem;
color: var(--text-muted);
font-family: 'Crimson Text', serif;
font-style: italic;
font-size: 1.2rem;
}
@media (max-width: 768px) {
.collection-page { padding: 6rem 1.2rem 3rem; }
.col-products-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
}
@media (max-width: 480px) {
.col-products-grid { grid-template-columns: 1fr; }
}
</style>
<div class="collection-page">
<div class="collection-header">
<div class="collection-eyebrow">✦ SOMBRAL ✦</div>
<h1 class="collection-title">{{ collection.title }}</h1>
{%- if collection.description != blank -%}
<div class="collection-desc">{{ collection.description }}</div>
{%- endif -%}
<p class="collection-count">{{ collection.products_count }} produto{% if collection.products_count != 1 %}s{% endif %} encontrado{% if collection.products_count != 1 %}s{% endif %}</p>
</div>
{%- if collection.products_count > 0 -%}
<div class="col-products-grid">
{%- for product in collection.products -%}
<a href="{{ product.url }}" class="col-product-card">
<div class="col-product-image">
{%- if product.featured_image -%}
<img src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
alt="{{ product.title | escape }}"
loading="lazy">
{%- else -%}
<div class="col-product-placeholder">✦</div>
{%- endif -%}
</div>
<div class="col-product-info">
<h3 class="col-product-title">{{ product.title }}</h3>
<div class="col-product-price">
{%- if product.compare_at_price > product.price -%}
<span class="col-price-old">{{ product.compare_at_price | money }}</span>
{%- endif -%}
<span class="col-price-current">{{ product.price | money }}</span>
</div>
<span class="col-btn-invocar">Invocar</span>
</div>
</a>
{%- endfor -%}
</div>
{%- else -%}
<div class="collection-empty">
<p>Nenhum produto encontrado nesta coleção.</p>
<a href="/collections/all" style="color:var(--cta);font-family:'Cinzel',serif;font-size:0.85rem;letter-spacing:0.1em;">← Ver Arsenal Completo</a>
</div>
{%- endif -%}
</div>

<header class="site-header">
<div class="header-inner">
<a href="/" class="header-logo">SOMBRAL</a>
<nav class="header-nav">
<a href="/collections/all">Arsenal</a>
<a href="/collections/rituais-divinacao">Rituais</a>
<a href="/collections/decoracao-das-sombras">Decoração</a>
<a href="/collections/identidade-dark">Identidade</a>
<a href="/collections/entrada-ate-r-51" style="color:#25d366;font-weight:700;">✦ Até R$50</a>
<a href="/apps/track123" style="color:var(--gold);" class="nav-rastrear">🔮 Rastrear Pedido</a>
</nav>
<div class="header-actions">
{% if customer %}
<a href="/account" class="btn-conta" title="Minha conta — {{ customer.first_name }}" aria-label="Minha conta">
<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
</a>
{% else %}
<a href="/account/login" class="btn-conta" title="Entrar na conta" aria-label="Entrar na conta">
<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
</a>
{% endif %}
<a href="/cart" class="cart-link">
🛒 <span class="cart-count">{{ cart.item_count }}</span>
</a>
</div>
<button class="mobile-menu-toggle" aria-label="Menu">☰</button>
</div>
<div class="mobile-nav" id="mobile-nav">
<a href="/collections/all">Arsenal</a>
<a href="/collections/rituais-divinacao">Rituais</a>
<a href="/collections/decoracao-das-sombras">Decoração</a>
<a href="/collections/identidade-dark">Identidade</a>
<a href="/collections/entrada-ate-r-51" style="color:#25d366;font-weight:700;">✦ Até R$50</a>
<a href="/apps/track123" style="color:var(--gold);">🔮 Rastrear Pedido</a>
{% if customer %}
<a href="/account">👤 Minha Conta</a>
<a href="/account/logout">Sair</a>
{% else %}
<a href="/account/login">👤 Entrar / Cadastrar</a>
{% endif %}
<a href="/cart">🛒 Carrinho ({{ cart.item_count }})</a>
</div>
<style>
.header-actions{display:flex;align-items:center;gap:0.6rem;}
.btn-conta{display:flex;align-items:center;justify-content:center;color:var(--text-muted);transition:color 0.2s;width:32px;height:32px;}
.btn-conta:hover{color:var(--gold);}
.cart-link{display:flex;align-items:center;gap:0.3rem;font-size:0.9rem;color:var(--text-muted);transition:color 0.2s;}
.cart-link:hover{color:var(--text);}
.nav-rastrear{position:relative;}
.nav-rastrear::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1px;background:var(--gold);transform:scaleX(0);transition:transform 0.2s;transform-origin:left;}
.nav-rastrear:hover::after{transform:scaleX(1);}
</style>
</header>
